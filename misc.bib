@book{mccleary,
	edition = {2},
	title = {A {User}'s {Guide} to {Spectral} {Sequences}},
	copyright = {https://www.cambridge.org/core/terms},
	isbn = {978-0-521-56141-9 978-0-521-56759-6 978-0-511-62628-9},
	url = {https://www.cambridge.org/core/product/identifier/9780511626289/type/book},
	doi = {10.1017/CBO9780511626289},
	abstract = {Spectral sequences are among the most elegant, most powerful, and most complicated methods of computation in mathematics. This book describes some of the most important examples of spectral sequences and some of their most spectacular applications. The first third of the book treats the algebraic foundations for this sort of homological algebra, starting from informal calculations, to give the novice a familiarity with the range of applications possible. The heart of the book is an exposition of the classical examples from homotopy theory, with chapters on the Leray-Serre spectral sequence, the Eilenberg-Moore spectral sequence, the Adams spectral sequence, and, in this new edition, the Bockstein spectral sequence. The last part of the book treats applications throughout mathematics, including the theory of knots and links, algebraic geometry, differential geometry and algebra. This is an excellent reference for students and researchers in geometry, topology, and algebra.},
	urldate = {2026-04-14},
	publisher = {Cambridge University Press},
	author = {McCleary, John},
	month = nov,
	year = {2000},
}

